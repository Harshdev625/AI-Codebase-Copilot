				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"harsh@aicc.dev\",\n    \"password\": \"password123\",\n    \"full_name\": \"Harsh Dev\"\n}",
							"options": {
								"raw": {
									"language": "json"
