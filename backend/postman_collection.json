		{
			"name": "Repositories",
			"item": [
				{
					"name": "Add Repository",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData && jsonData.success && jsonData.data && jsonData.data.id) {",
									"    pm.collectionVariables.set(\"repositoryId\", jsonData.data.id);",
									"    pm.environment.set(\"repositoryId\", jsonData.data.id);",
									"}",
									"if (jsonData && jsonData.success && jsonData.data && jsonData.data.repo_id) {",
									"    pm.collectionVariables.set(\"repoId\", jsonData.data.repo_id);",
									"    pm.environment.set(\"repoId\", jsonData.data.repo_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"repo_id\": \"Harshdev625/AI-Codebase-Copilot\",\n    \"remote_url\": \"https://github.com/Harshdev625/AI-Codebase-Copilot\",\n    \"default_branch\": \"main\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/v1/projects/{{projectId}}/repositories",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"v1",
								"projects",
								"{{projectId}}",
								"repositories"
							]
						}
					},
					"response": []
				},
