APP_NAME=AI Codebase Copilot API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
OLLAMA_CHAT_MODEL=qwen2.5-coder
OLLAMA_TIMEOUT_SECONDS=60

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=code_chunks

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_TTL_SECONDS=300

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aicc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mypassword

# PgAdmin (runs via Podman on port 5050)
# URL: http://localhost:5050  |  Login: admin@aicc.local / admin

# Must match selected embedding model dimension (default mxbai-embed-large = 1024)
VECTOR_DIM=1024
MAX_RETRIEVAL_K=12
REPO_CACHE_DIR=.repo_cache
MAX_INDEX_FILE_SIZE_BYTES=1000000

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ISSUER=ai-codebase-copilot
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=28800

# Optional bootstrap admin (created/promoted on API startup)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=Administrator
