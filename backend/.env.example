APP_NAME=AI Codebase Copilot API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
OLLAMA_TIMEOUT_SECONDS=60

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aicc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mypassword

# PgAdmin (runs via Podman on port 5050)
# URL: http://localhost:5050  |  Login: admin@aicc.local / admin

# Must match selected embedding model dimension (default mxbai-embed-large = 1024)
VECTOR_DIM=1024
MAX_RETRIEVAL_K=12
REPO_CACHE_DIR=.repo_cache
MAX_INDEX_FILE_SIZE_BYTES=1000000
